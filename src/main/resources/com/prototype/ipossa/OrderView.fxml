<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #feb5a3;"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.prototype.ipossa.views.OrderView">
    <left>
    <VBox alignment="TOP_CENTER" spacing="10" style="-fx-padding: 1;">
        <Label text="Show Orders" style="-fx-font-size: 11px; -fx-font-weight: lighter;"/>

        <Button onAction="#showOrders" prefWidth="50"
                style="-fx-background-color: #6a2222; -fx-text-fill: black; -fx-font-weight: bold;"/>
    </VBox>
    </left>
</BorderPane>
